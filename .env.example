# Copy this file to .env.local for local development.
# On Vercel, set these under Project Settings → Environment Variables instead —
# never commit real secrets to GitHub.

# Postgres connection string. Easiest source: Vercel → Storage → Create Database → Postgres
# (powered by Neon). Vercel injects this automatically once you connect the database
# to this project — you often won't need to set it by hand.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# A long random string used to sign admin session cookies.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET="replace-with-a-long-random-string-at-least-32-characters"

# Your live site URL (used to build PayFast return/cancel/notify links).
# Set this to your real Vercel URL or custom domain once deployed.
NEXT_PUBLIC_SITE_URL="https://your-project.vercel.app"

# Vercel Blob storage token, for course photo/material uploads.
# Vercel → Storage → Create → Blob — it injects this automatically once connected.
BLOB_READ_WRITE_TOKEN=""
